{
    "name": "macropage/plentyone-php-sdk",
    "description": "PlentyOne REST API SDK based on Saloon PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "macropage",
            "email": "info@macropage.de"
        }
    ],
    "require": {
        "php": "^8.2",
        "saloonphp/saloon": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "PlentyOne\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PlentyOne\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "rector/rector": "^2.4",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "erickskrauch/php-cs-fixer-custom-fixers": "^1.3"
    }
}
